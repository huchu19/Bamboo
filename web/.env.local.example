# Firebase Configuration — copy to .env.local and fill in
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_auth_domain
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_storage_bucket
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Stripe — get test keys at https://dashboard.stripe.com/test/apikeys.
# While these are *_stub, the invest flow uses the demo simulation instead.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_stub
STRIPE_SECRET_KEY=sk_test_stub
# From `stripe listen --forward-to localhost:3000/api/stripe/webhook` (dev)
# or the webhook endpoint config in the Stripe dashboard (prod).
STRIPE_WEBHOOK_SECRET=

# Firebase Admin SDK (server routes/webhooks). Optional locally — falls back to
# scripts/service-account.json. REQUIRED on Vercel: full service-account JSON
# as a single line.
# FIREBASE_SERVICE_ACCOUNT_KEY=

# Dev bypass — true for local demo iteration, MUST be false in production.
# Vercel prod sets this to false; preview deploys can override per-env.
NEXT_PUBLIC_DEV_BYPASS_AUTH=true

# Public site URL — used for OG/Twitter image absolute URLs and canonical links.
# Vercel auto-provides VERCEL_URL as a fallback for previews; set this explicitly in prod.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
